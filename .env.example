PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3001
CUSTOMER_APP_BASE_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=product-images
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3001/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3001/cart
STRIPE_SHIPPING_RATE_CENTS=1500
ORDER_TOKEN_PEPPER=replace-with-a-long-random-string

# Optional backend-only values
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=orders@example.com

# The configured bucket must already exist in Supabase Storage and be public for image URLs to resolve.
# CUSTOMER_APP_BASE_URL and STRIPE_SHIPPING_RATE_CENTS do not have safe production defaults.
# When enabling email sending, set both RESEND_API_KEY and RESEND_FROM_EMAIL together.
# Startup validation rejects missing or structurally invalid required values.

# Deprecated compatibility aliases
# FRONTEND_BASE_URL=http://localhost:3001
# SUPABASE_SECRET_KEY=your-supabase-service-role-key
